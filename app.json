{
  "expo": {
    "name": "CulturePass.App",
    "slug": "culturepass",
    "version": "1.0.0",
    "description": "CulturePass - Your one-stop lifestyle platform for cultural diaspora communities. Discover events, connect with communities, and celebrate diversity across Australia, New Zealand, UAE, UK & Canada.",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "culturepass",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FBF8F4"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "au.culturepass.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "CulturePass uses your location to show events and communities near you.",
        "NSCameraUsageDescription": "CulturePass uses the camera to update your profile photo.",
        "NSPhotoLibraryUsageDescription": "CulturePass accesses your photo library to update your profile photo.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "usesNonExemptEncryption": false
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          }
        ]
      }
    },
    "android": {
      "package": "au.culturepass.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "READ_EXTERNAL_STORAGE",
        "VIBRATE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png",
      "name": "CulturePass.App - Cultural Events & Communities Platform",
      "shortName": "CulturePass.App",
      "description": "Discover cultural events, join diaspora communities, find local businesses, and celebrate diversity. CulturePass connects you with cultural experiences across Australia, New Zealand, UAE, UK & Canada.",
      "lang": "en",
      "themeColor": "#007AFF",
      "backgroundColor": "#F2F2F7",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "@react-native-google-signin/google-signin",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "CulturePass uses your location to show events and communities near you."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "315fb04d-254b-4915-9c5b-ca7faf0c54cf"
      }
    },
    "owner": "airpizza"
  }
}
