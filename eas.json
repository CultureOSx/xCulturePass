{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
      ,
      "env": {
        "EXPO_PUBLIC_FIREBASE_API_KEY": "__SET_IN_SECRETS__",
        "EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN": "__SET_IN_SECRETS__",
        "EXPO_PUBLIC_FIREBASE_PROJECT_ID": "__SET_IN_SECRETS__",
        "EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET": "__SET_IN_SECRETS__",
        "EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID": "__SET_IN_SECRETS__",
        "EXPO_PUBLIC_FIREBASE_APP_ID": "__SET_IN_SECRETS__"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
      ,
      "env": {
        "EXPO_PUBLIC_FIREBASE_API_KEY": "__SET_IN_SECRETS__",
        "EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN": "__SET_IN_SECRETS__",
        "EXPO_PUBLIC_FIREBASE_PROJECT_ID": "__SET_IN_SECRETS__",
        "EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET": "__SET_IN_SECRETS__",
        "EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID": "__SET_IN_SECRETS__",
        "EXPO_PUBLIC_FIREBASE_APP_ID": "__SET_IN_SECRETS__"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "simulator": false
      }
      ,
      "env": {
        "EXPO_PUBLIC_FIREBASE_API_KEY": "__SET_IN_SECRETS__",
        "EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN": "__SET_IN_SECRETS__",
        "EXPO_PUBLIC_FIREBASE_PROJECT_ID": "__SET_IN_SECRETS__",
        "EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET": "__SET_IN_SECRETS__",
        "EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID": "__SET_IN_SECRETS__",
        "EXPO_PUBLIC_FIREBASE_APP_ID": "__SET_IN_SECRETS__"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "FILL_IN_APPLE_ID_EMAIL",
        "ascAppId": "FILL_IN_APP_STORE_CONNECT_APP_ID",
        "appleTeamId": "FILL_IN_APPLE_TEAM_ID"
      },
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "track": "production"
      }
    }
  }
}
