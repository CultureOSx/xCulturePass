# ──────────────────────────────────────────────────────────────────────────────
# CulturePass AU — Environment Variables
# Copy this file to .env (never commit .env)
# Get Firebase values from: Firebase Console → Project Settings → Your apps
# ──────────────────────────────────────────────────────────────────────────────

# Firebase Client SDK (baked into Expo bundle — safe to expose publicly)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Cloud Functions URL — keep trailing slash
EXPO_PUBLIC_API_URL=https://us-central1-YOUR_PROJECT_ID.cloudfunctions.net/api/

# Optional: local Firebase emulators during development
EXPO_PUBLIC_USE_FIREBASE_EMULATORS=false
EXPO_PUBLIC_FIREBASE_EMULATOR_HOST=127.0.0.1

# ──────────────────────────────────────────────────────────────────────────────
# Cloud Functions secrets (functions/.env) — never in Expo bundle
# ──────────────────────────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_MONTHLY_ID=price_...
# STRIPE_PRICE_YEARLY_ID=price_...
