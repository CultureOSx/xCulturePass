rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function hasRole(role) {
      return isSignedIn() && request.auth.token.role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isOrganizer() {
      return hasRole('organizer');
    }

    // Users: Only owner or admin can write, anyone can read public profiles
    match /users/{uid} {
      allow read: if true;
      allow write: if isOwner(uid) || isAdmin();
      // User subcollections: Only owner can access
      match /{collection}/{docId} {
        allow read, write: if isOwner(uid) && collection in ['tickets', 'savedEvents', 'calendar', 'notifications', 'perks', 'communities'];
      }
    }

    // Events: Anyone can read published, only organizer/admin can write
    match /events/{eventId} {
      allow read: if resource.data.status == 'published';
      allow write: if isSignedIn() && (isOrganizer() || isAdmin());
      // Event subcollections: Only organizer/admin can write, attendees can read their own tickets
      match /{collection}/{docId} {
        allow read: if true;
        allow write: if (isOrganizer() || isAdmin()) && collection in ['tickets', 'attendees', 'reviews', 'comments', 'media'];
      }
    }

    // Communities: Anyone can read, only admin/owner can write
    match /communities/{communityId} {
      allow read: if true;
      allow write: if isAdmin() || isOrganizer();
      match /members/{memberId} {
        allow read: if true;
        allow write: if isAdmin() || isOrganizer();
      }
      match /events/{eventId} {
        allow read: if true;
        allow write: if isAdmin() || isOrganizer();
      }
      match /council/{councilId} {
        allow read: if true;
        allow write: if isAdmin() || isOrganizer();
      }
    }

    // Council: Only council members/admin can write, anyone can read
    match /council/{councilId} {
      allow read: if true;
      allow write: if isAdmin() || isOrganizer();
      match /members/{memberId} {
        allow read: if true;
        allow write: if isAdmin() || isOrganizer();
      }
      match /events/{eventId} {
        allow read: if true;
        allow write: if isAdmin() || isOrganizer();
      }
      match /claims/{claimId} {
        allow read: if true;
        allow write: if isAdmin() || isOrganizer();
      }
    }

    // Perks: Anyone can read, only admin can write
    match /perks/{perkId} {
      allow read: if true;
      allow write: if isAdmin();
      match /redemptions/{redemptionId} {
        allow read: if true;
        allow write: if isOwner(request.auth.uid) || isAdmin();
      }
    }

    // Tickets: Only owner or event organizer can read/write
    match /tickets/{ticketId} {
      allow read, write: if isOwner(resource.data.userId) || isOrganizer() || isAdmin();
    }

    // Feed: Only owner can read/write
    match /feed/{feedId} {
      allow read, write: if isOwner(resource.data.userId);
    }

    // Notifications: Only recipient can read/write
    match /notifications/{notificationId} {
      allow read, write: if isOwner(resource.data.userId);
    }

    // Profiles: Anyone can read, only owner/admin can write
    match /profiles/{profileId} {
      allow read: if true;
      allow write: if isOwner(resource.data.ownerId) || isAdmin();
    }

    // Locations: Anyone can read, only admin can write
    match /locations/{countryCode} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Default: deny all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
